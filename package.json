{
  "name": "kurchu-crm-backend",
  "version": "1.0.0",
  "description": "Kurchu CRM — Production-grade Customer Relationship Management API",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "prisma:generate": "npx prisma generate --schema=src/database/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=src/database/prisma/schema.prisma",
    "prisma:migrate:prod": "npx prisma migrate deploy --schema=src/database/prisma/schema.prisma",
    "prisma:seed": "node src/database/seeds/seed.js",
    "prisma:studio": "npx prisma studio --schema=src/database/prisma/schema.prisma",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix"
  },
  "keywords": ["crm", "sales", "dashboard", "api", "express"],
  "author": "Kurchu Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.6",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.1",
    "winston": "^3.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.0.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/fixtures/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "nodemonConfig": {
    "watch": ["src/", "server.js"],
    "ext": "js,json",
    "ignore": ["tests/", "node_modules/", "logs/"]
  }
}

# ============================================
# Kurchu CRM Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kurchu_crm

# JWT Secrets (use strong random strings, 32+ characters)
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars_long_change_me
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars_long_change_me

# JWT Token Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Kurchu CRM <noreply@kurchucrm.com>"

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Session/Cookies
SESSION_SECRET=your_session_secret_min_32_chars_long_change_me
